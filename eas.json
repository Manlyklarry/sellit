{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "20.19.4",
      "android": {
        "image": "sdk-54"
      },
      "ios": {
        "image": "sdk-54"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },
    "development-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "environment": "preview"
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "environment": "production"
    }
  }
}
